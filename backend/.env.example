# Copy to backend/.env and fill in. All values have safe defaults except the API keys.

# --- Database ---
# Local docker-compose Postgres (see docker-compose.yml at the repo root):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/newsai
# Neon / managed Postgres example (sslmode is handled automatically):
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/newsai?sslmode=require
# On serverless platforms, prefer the pooled connection string and set:
# DB_USE_NULL_POOL=true

# --- News provider (https://gnews.io — free tier: 100 requests/day) ---
GNEWS_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-nano

# --- CORS (comma-separated browser origins allowed to call the API) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Auth (WorkOS AuthKit) ---
# Leave blank to run WITHOUT auth (local "dev mode": no login, single local user).
# Set all three to require sign-in — get them from the WorkOS dashboard.
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
# Must be >= 32 chars: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=
# Registered redirect URI. Local dev goes through the Vite proxy so the session
# cookie stays same-origin:
WORKOS_REDIRECT_URI=http://localhost:5173/api/auth/callback
# SPA origin to return to after login/logout:
APP_BASE_URL=http://localhost:5173
